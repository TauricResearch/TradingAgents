# LLM Provider API Keys (set only the one you use)
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM settings
TRADINGAGENTS_LLM_PROVIDER=google
TRADINGAGENTS_DEEP_THINK_LLM=gemini-2.5-flash
TRADINGAGENTS_QUICK_THINK_LLM=gemini-2.5-flash

# Redis connection (use service name in Docker)
REDIS_URL=redis://pulse-trading-signals-redis:6379/0

# JWT — must match pulse-auth-service JWT_SECRET_KEY
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256

# Free tier quota (views per 24h)
FREE_TIER_QUOTA_LIMIT=3

# Internal API key for service-to-service calls
INTERNAL_API_KEY=your_internal_api_key_here

# Auth service base URL (for entitlement resolution)
AUTH_SERVICE_URL=https://staging-backend.pulsenow.io
