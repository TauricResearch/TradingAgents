# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_VERSION=2024-10-21  # optional, required for non-v1 API

# AWS Bedrock (uses standard AWS credential chain)
# Authentication: set ONE of the following methods:
#   Method 1 - Access keys:
#     AWS_ACCESS_KEY_ID=your-access-key
#     AWS_SECRET_ACCESS_KEY=your-secret-key
#   Method 2 - Named profile:
#     AWS_PROFILE=your-profile-name
#   Method 3 - IAM role: no env vars needed (auto-detected on EC2/ECS/Lambda)
#   Method 4 - SSO: run `aws sso login` first
#
# Region (optional, defaults to us-east-1):
# AWS_BEDROCK_REGION=us-east-1
#
# Timeout (optional, defaults to 300s for agentic workflows):
# BEDROCK_TIMEOUT=300
#
# Note: If AWS_BEARER_TOKEN_BEDROCK is set in your environment (e.g. for
# Claude Code), TradingAgents automatically ignores it to prevent auth conflicts.
