# LLM Provider
ANTHROPIC_API_KEY=

# Data Providers
ALPHA_VANTAGE_API_KEY=

# Notion (optional — required only for publishing reports to Notion)
# 1. Create an integration at https://www.notion.so/my-integrations and copy the secret.
# 2. Open the target Notion page, click Share → Connections → connect your integration.
# 3. Copy the page ID from its URL (32-char hex after the last dash, e.g. abc123...).
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=https://www.notion.so/
