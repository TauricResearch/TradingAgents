# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# ── Daily Scheduler (daily_scheduler.py) ────────────────────────────────────

# LLM model overrides
DEEP_THINK_LLM=gpt-5.4-mini
QUICK_THINK_LLM=gpt-5.4-mini
MAX_DEBATE_ROUNDS=1

# Scheduler timing
RUN_AT=06:00          # 24-hour local time
RUN_NOW=false         # set to true to also run immediately on startup

# Upload mode: email | s3 | none
UPLOAD_MODE=email

# Email upload (UPLOAD_MODE=email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# S3 upload (UPLOAD_MODE=s3)
S3_BUCKET=
S3_PREFIX=trading-reports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
