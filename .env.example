# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Broker (execution) — Alpaca paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Market data vendors
# FRED (macro: GDP, CPI, fed funds, unemployment, 10y). Free key at
# https://fredapi.stlouisfed.org / fred.stlouisfed.org -> My Account -> API Keys.
# Without it the Market desk simply runs without macro.
FRED_API_KEY=
# News (yfinance) and social sentiment (StockTwits) need no key.

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# Default = OpenRouter with FREE models (see default_config.py); you only need
# OPENROUTER_API_KEY above. Override with the exact OpenRouter slugs you want
# (verify them on openrouter.ai — free slugs end in :free). Examples:
#TRADINGAGENTS_LLM_PROVIDER=openrouter
#TRADINGAGENTS_DEEP_THINK_LLM=deepseek/deepseek-v4-flash:free
#TRADINGAGENTS_QUICK_THINK_LLM=deepseek/deepseek-v4-flash:free
# alt deep thinker (verify slug): #TRADINGAGENTS_DEEP_THINK_LLM=openrouter/owl-alpha
#TRADINGAGENTS_LLM_BACKEND_URL=

# Broker: set both Alpaca keys (above) to trade on a real Alpaca PAPER account;
# leave them empty to use the in-process PaperBroker simulator.
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false

# LangSmith — tracing for LangGraph and LangChain
# Get your API key at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=trading-agent

# Persistence layer (tradingagents/storage)
# Unset -> local SQLite at ~/.tradingagents/trading_agent.db (zero setup).
# Point at PostgreSQL/TimescaleDB for production; price_bars becomes a hypertable.
#TRADINGAGENTS_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/trading_agent
