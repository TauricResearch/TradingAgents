# =============================
# TradingAgents Web — .env
# Copy this file to .env and fill in your values.
# =============================

# --- Auth ---
# Long random string (32+ chars). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-character-string

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://tradingagents:tradingagents@localhost:5432/tradingagents

# --- Encryption (for broker API keys stored in DB) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- LLM Providers (carried from existing project) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Data Providers ---
ALPHA_VANTAGE_API_KEY=

# --- Optional ---
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-4o
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-4o-mini
