# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
# OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# Use the registered "anthropic" client; ChatAnthropic reads ANTHROPIC_API_KEY
# from env and posts to ${backend_url}/v1/messages, so set backend_url to the
# gateway root (no trailing /v1) to avoid /v1/v1/messages.
# TRADINGAGENTS_LLM_PROVIDER=openai
# TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
# TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.5
TRADINGAGENTS_LLM_PROVIDER=anthropic
TRADINGAGENTS_DEEP_THINK_LLM=claude-opus-4-8
TRADINGAGENTS_QUICK_THINK_LLM=claude-haiku-4-5
# Reports save root. Lives inside docs/ so GitHub Pages can publish it
# directly (Settings → Pages → Source: main + /docs). Inside Docker,
# docker-compose bind-mounts the same host path to the same container
# path, so this works in both modes.
TRADINGAGENTS_REPORTS_DIR=/.../docs
TRADINGAGENTS_OUTPUT_LANGUAGE=English
TRADINGAGENTS_MAX_DEBATE_ROUNDS=5
TRADINGAGENTS_MAX_RISK_ROUNDS=5
TRADINGAGENTS_CHECKPOINT_ENABLED=true
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#TRADINGAGENTS_TEMPERATURE=0.0
