# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# AWS Bedrock (uses standard AWS credential chain)
# Authentication: set ONE of the following methods:
#   Method 1 - Access keys:
#     AWS_ACCESS_KEY_ID=your-access-key
#     AWS_SECRET_ACCESS_KEY=your-secret-key
#   Method 2 - Named profile:
#     AWS_PROFILE=your-profile-name
#   Method 3 - IAM role: no env vars needed (auto-detected on EC2/ECS/Lambda)
#
# Region (optional, defaults to us-east-1):
# AWS_BEDROCK_REGION=us-east-1
