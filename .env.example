# ============================================================
# TradingAgents — .env örneği
# Bu dosyayı .env olarak kopyala ve değerleri doldur.
# cp .env.example .env
# ============================================================

# --- Auth ---
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-character-string
ADMIN_USERNAME=admin
# python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# --- Database ---
DATABASE_URL=postgresql+asyncpg://tradingagents:tradingagents@localhost:5432/tradingagents

# --- Encryption ---
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================================
# LLM Provider API Keys — Kullandığın provider'ı doldur
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
LITELLM_API_KEY=
AZURE_OPENAI_API_KEY=

# ============================================================
# Data Provider API Keys
# ============================================================
ALPHA_VANTAGE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingAgents/1.0

# ============================================================
# Search Engine (Searxng)
# ============================================================
SEARXNG_URL=http://localhost:8080

